# Caddy reverse proxy for Fridge Monitor Grafana
#
# TLS certificate is obtained via DNS-01 challenge using the name.com API.
# This requires no inbound port 80 — only port 8443 needs to be forwarded.
# DuckDNS handles dynamic IP updates separately (see duckdns service).
#
# {$DOMAIN}, {$NAMEDOTCOM_USER}, {$NAMEDOTCOM_API_TOKEN} set from docker-compose.yml env vars.

{$DOMAIN} {
    tls {
        dns namedotcom {
            user   {$NAMEDOTCOM_USER}
            token  {$NAMEDOTCOM_API_TOKEN}
            server https://api.name.com
        }
    }

    # ── Alert management ────────────────────────────────────────────────────
    # Auth: the frontend collects Grafana credentials and sends them as HTTP
    # Basic auth; alert-api validates them against Grafana /api/user.
    # No separate basicauth or injected bearer token needed.

    handle /alerts/api/* {
        reverse_proxy alert-api:8000
    }

    handle /alerts/* {
        root * /srv/alert-ui
        file_server
    }

    # ── Grafana (catch-all) ─────────────────────────────────────────────────
    reverse_proxy grafana:3000

    header {
        Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
        X-Content-Type-Options "nosniff"
        X-XSS-Protection "1; mode=block"
        -X-Frame-Options
    }

    log {
        output stdout
        format json
    }
}
