# =============================================================================
# Fridge Monitoring Stack — Configuration Template
# =============================================================================
# Copy this file to .env and fill in every value before running install.sh.
#   cp .env.example .env
#
# .env is gitignored. Never commit it.
# =============================================================================


# -----------------------------------------------------------------------------
# Domain & public URL
# -----------------------------------------------------------------------------

# Fully-qualified domain name pointing at this server.
# Used by Caddy for TLS certificate acquisition and Grafana's root URL.
DOMAIN=fridge.zickers.us:8443

# Full public URL for Grafana (must match DOMAIN above).
# Used in Grafana's absolute link generation and Alertmanager alert links.
GRAFANA_PUBLIC_URL=https://fridge.zickers.us:8443


# -----------------------------------------------------------------------------
# Grafana — admin account
# -----------------------------------------------------------------------------

# Admin username (default: admin).
GF_ADMIN_USER=admin

# Admin password. Change before exposing to the internet.
GF_ADMIN_PASSWORD=changeme


# -----------------------------------------------------------------------------
# Grafana — lab user account (Editor role, for day-to-day lab use)
# -----------------------------------------------------------------------------

# Login name shown on sign-in page.
LAB_USER_LOGIN=labuser

# Display name shown in Grafana UI.
LAB_USER_NAME="Lab User"

# Password for the lab user account.
LAB_USER_PASSWORD=changeme

# Email address (used for Grafana notifications to this user).
LAB_USER_EMAIL=wanglab@university.edu


# -----------------------------------------------------------------------------
# Email — SendGrid SMTP relay
# -----------------------------------------------------------------------------
# Sign up at sendgrid.com (free tier: 100 emails/day).
# Create a Single Sender or verify a domain, then generate an API key
# with "Mail Send" permission.

SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587

# SendGrid uses the literal string "apikey" as the SMTP username.
SMTP_USER=apikey

# Paste your SendGrid API key here (starts with SG.).
SMTP_PASSWORD=SG.your-api-key-here

# The "From" address on outgoing alert emails.
# Must match your verified SendGrid sender or domain.
SMTP_FROM=alerts@fridge.zickers.us

# Comma-separated list of email addresses to receive alerts.
ALERT_EMAIL_TO=person1@gmail.com,person2@icloud.com


# -----------------------------------------------------------------------------
# Slack alerts
# -----------------------------------------------------------------------------
# Create an Incoming Webhook at api.slack.com/messaging/webhooks.
# The URL format is: https://hooks.slack.com/services/T.../B.../...

SLACK_WEBHOOK_URL=https://hooks.slack.com/services/REPLACE/WITH/YOUR_WEBHOOK
SLACK_CHANNEL=#fridge-alerts


# -----------------------------------------------------------------------------
# Dynamic DNS — DuckDNS
# -----------------------------------------------------------------------------
# DuckDNS keeps zickers-fridge.duckdns.org pointed at this server's current IP.
# name.com fridge.zickers.us has a CNAME record → zickers-fridge.duckdns.org,
# so the public domain always resolves correctly even when the server IP changes.
#
# Get your token at https://www.duckdns.org (sign in → copy the token shown).
# DUCKDNS_SUBDOMAINS: just the subdomain part (e.g. zickers-fridge, not the full domain)
# DUCKDNS_TOKEN:      your DuckDNS account token

DUCKDNS_SUBDOMAINS=zickers-fridge
DUCKDNS_TOKEN=your-duckdns-token-here

# -----------------------------------------------------------------------------
# TLS certificate — name.com API (DNS-01 challenge via Caddy)
# -----------------------------------------------------------------------------
# Used by Caddy to create the _acme-challenge TXT record on fridge.zickers.us.
# Generate an API token at: name.com → Account → API credentials
# NAMEDOTCOM_USER:      your name.com account username
# NAMEDOTCOM_API_TOKEN: the API token (not your account password)

NAMEDOTCOM_USER=your-namedotcom-username   # include any special characters e.g. hools!
NAMEDOTCOM_API_TOKEN=your-namedotcom-api-token


# -----------------------------------------------------------------------------
# Prometheus data retention
# Both limits apply simultaneously — whichever is hit first triggers cleanup.
# With 30d and 15GB cap, expect ~500MB/day per fridge for full sensor sets.
# -----------------------------------------------------------------------------

PROMETHEUS_RETENTION_TIME=30d
PROMETHEUS_RETENTION_SIZE=15GB


# -----------------------------------------------------------------------------
# Security — Pushgateway access control
# -----------------------------------------------------------------------------
# Restrict which IPs can push metrics to port 9091.
# Set to your college network CIDR (e.g. 10.0.0.0/8 or 192.168.1.0/24).
# Leave empty to allow all (insecure — fill this in once IT provides the range).
# Requires ufw to be installed on the host.

ALLOWED_PUSH_CIDR=


# -----------------------------------------------------------------------------
# Watchtower — container update notifications
# -----------------------------------------------------------------------------
# Watchtower runs in monitor-only mode (never auto-updates containers).
# It emails this address when new image versions are available.

WATCHTOWER_NOTIFY_EMAIL=admin@example.com


# -----------------------------------------------------------------------------
# Alert API service
# -----------------------------------------------------------------------------
# Grafana service account token for the alert-api (auto-generated by install.sh).
# The service account (Editor role) performs create/delete operations on behalf
# of any authenticated lab user.  Leave empty — install.sh will create the
# service account and populate this value on first run.
GRAFANA_SA_TOKEN=
