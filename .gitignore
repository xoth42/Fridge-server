# Python runtime artifacts
__pycache__/
*.pyc

# Docker-managed data volumes (never commit these)
data/
prometheus-data/
grafana-data/
alertmanager-data/

# Environment file — contains secrets.
# Copy .env.example → .env and fill in values. Never commit .env.
.env

# Generated configs from *.template files (created by install.sh).
#
# config/alertmanager/alertmanager.yml — IS tracked in git (log-only default).
#   install.sh overwrites it locally with real credentials.
#   Do NOT stage/commit it after running install.sh.
#   To restore the committed default: git checkout config/alertmanager/alertmanager.yml

